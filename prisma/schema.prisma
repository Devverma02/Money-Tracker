generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PreferredLanguage {
  HINDI
  HINGLISH
  ENGLISH
}

enum EntryInputPreference {
  TYPING
  MIC
}

enum CurrencyCode {
  INR
  USD
  AED
  EUR
  GBP
}

enum BucketKind {
  PERSONAL
  GHAR
  DUKAAN
  KHETI
  CUSTOM
}

enum SourceMode {
  TEXT
  VOICE
  MANUAL
  IMPORT
}

enum EntryType {
  EXPENSE
  INCOME
  LOAN_GIVEN
  LOAN_TAKEN
  LOAN_RECEIVED_BACK
  LOAN_REPAID
  SAVINGS_DEPOSIT
  NOTE
  REMINDER
}

enum ReminderStatus {
  PENDING
  DONE
  SNOOZED
  OVERDUE
  CANCELLED
}

enum OpeningLoanDirection {
  RECEIVABLE
  PAYABLE
}

model AppProfile {
  id                String              @id @db.Uuid
  email             String?             @unique
  displayName       String?
  preferredLanguage PreferredLanguage   @default(HINGLISH)
  timezone          String              @default("Asia/Kolkata")
  preferredCurrency CurrencyCode        @default(INR)
  voiceRepliesEnabled Boolean           @default(true)
  reminderDefaultTime String            @default("09:00")
  preferredEntryInput EntryInputPreference @default(TYPING)
  hasCompletedSetup  Boolean            @default(false)
  balanceGuardEnabled Boolean           @default(true)
  openingBalance     Decimal            @default(0) @db.Decimal(12, 2)
  setupCompletedAt   DateTime?
  defaultBucketId   String?             @db.Uuid
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  defaultBucket     Bucket?             @relation("DefaultBucket", fields: [defaultBucketId], references: [id], onDelete: SetNull)
  buckets           Bucket[]            @relation("ProfileBuckets")
  openingLoanPositions OpeningLoanPosition[]
  ledgerEntries     LedgerEntry[]
  reminders         Reminder[]
  corrections       EntryCorrection[]   @relation("CorrectionActor")
  auditLogs         AuditLog[]          @relation("AuditActor")
  people            Person[]
  categoryAliases   CategoryAlias[]
  pushSubscriptions PushSubscription[]
  askAiDocuments    AskAiDocument[]
}

model Bucket {
  id                 String       @id @default(uuid()) @db.Uuid
  userId             String       @db.Uuid
  name               String
  slug               String
  kind               BucketKind   @default(PERSONAL)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  user               AppProfile   @relation("ProfileBuckets", fields: [userId], references: [id], onDelete: Cascade)
  defaultForProfiles AppProfile[] @relation("DefaultBucket")
  ledgerEntries      LedgerEntry[]
  reminders          Reminder[]

  @@unique([userId, slug])
  @@index([userId, kind])
}

model LedgerEntry {
  id                   String            @id @default(uuid()) @db.Uuid
  userId               String            @db.Uuid
  bucketId             String?           @db.Uuid
  sourceMode           SourceMode        @default(TEXT)
  sourceText           String?
  amount               Decimal           @db.Decimal(12, 2)
  entryType            EntryType
  category             String?
  entryDate            DateTime
  personName           String?
  note                 String?
  parserConfidence     Decimal?          @db.Decimal(4, 3)
  requiresConfirmation Boolean           @default(false)
  duplicateFingerprint String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  user                 AppProfile        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bucket               Bucket?           @relation(fields: [bucketId], references: [id], onDelete: SetNull)
  corrections          EntryCorrection[]
  reminders            Reminder[]

  @@index([userId, entryDate])
  @@index([userId, personName])
  @@index([userId, duplicateFingerprint])
}

model EntryCorrection {
  id             String      @id @default(uuid()) @db.Uuid
  entryId        String      @db.Uuid
  actorUserId    String      @db.Uuid
  reason         String?
  sourceText     String?
  beforeSnapshot Json
  afterSnapshot  Json
  createdAt      DateTime    @default(now())
  entry          LedgerEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  actor          AppProfile  @relation("CorrectionActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([entryId, createdAt])
  @@index([actorUserId, createdAt])
}

model Reminder {
  id           String         @id @default(uuid()) @db.Uuid
  userId       String         @db.Uuid
  bucketId     String?        @db.Uuid
  title        String
  linkedPerson String?
  linkedEntryId String?       @db.Uuid
  dueAt        DateTime
  status       ReminderStatus @default(PENDING)
  snoozeUntil  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         AppProfile     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bucket       Bucket?        @relation(fields: [bucketId], references: [id], onDelete: SetNull)
  linkedEntry  LedgerEntry?   @relation(fields: [linkedEntryId], references: [id], onDelete: SetNull)
  pushDeliveries ReminderPushDelivery[]

  @@index([userId, status, dueAt])
}

model OpeningLoanPosition {
  id                   String               @id @default(uuid()) @db.Uuid
  userId               String               @db.Uuid
  personName           String
  normalizedPersonName String
  direction            OpeningLoanDirection
  amount               Decimal              @db.Decimal(12, 2)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  user                 AppProfile           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, normalizedPersonName])
  @@index([userId, direction])
}

model PushSubscription {
  id           String                 @id @default(uuid()) @db.Uuid
  userId       String                 @db.Uuid
  endpoint     String                 @unique
  p256dh       String
  auth         String
  expiresAt    DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  lastSuccessAt DateTime?
  user         AppProfile             @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries   ReminderPushDelivery[]

  @@index([userId, updatedAt])
}

model ReminderPushDelivery {
  id                 String           @id @default(uuid()) @db.Uuid
  reminderId         String           @db.Uuid
  pushSubscriptionId String           @db.Uuid
  dueAtSnapshot      DateTime
  sentAt             DateTime         @default(now())
  reminder           Reminder         @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  pushSubscription   PushSubscription @relation(fields: [pushSubscriptionId], references: [id], onDelete: Cascade)

  @@unique([reminderId, pushSubscriptionId, dueAtSnapshot])
  @@index([pushSubscriptionId, sentAt])
}

model Person {
  id                    String        @id @default(uuid()) @db.Uuid
  userId                String        @db.Uuid
  displayName           String
  normalizedDisplayName String
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  user                  AppProfile    @relation(fields: [userId], references: [id], onDelete: Cascade)
  aliases               PersonAlias[]

  @@unique([userId, normalizedDisplayName])
  @@index([userId, createdAt])
}

model PersonAlias {
  id              String   @id @default(uuid()) @db.Uuid
  personId        String   @db.Uuid
  alias           String
  normalizedAlias String
  createdAt       DateTime @default(now())
  person          Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([personId, normalizedAlias])
  @@index([normalizedAlias])
}

model CategoryAlias {
  id                      String     @id @default(uuid()) @db.Uuid
  userId                  String     @db.Uuid
  canonicalName           String
  normalizedCanonicalName String
  alias                   String
  normalizedAlias         String
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
  user                    AppProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedAlias])
  @@index([userId, normalizedCanonicalName])
}

model AskAiDocument {
  id         BigInt   @id @default(autoincrement())
  userId     String   @db.Uuid @map("user_id")
  sourceType String   @map("source_type")
  sourceId   String   @map("source_id")
  content    String
  metadata   Json     @default("{}")
  contentTsv Unsupported("tsvector") @map("content_tsv") @default(dbgenerated())
  embedding  Unsupported("vector")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       AppProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceType, sourceId], map: "ask_ai_documents_source_unique")
  @@index([userId], map: "ask_ai_documents_user_id_idx")
  @@map("ask_ai_documents")
}

model AuditLog {
  id            String     @id @default(uuid()) @db.Uuid
  correlationId String
  actorUserId   String     @db.Uuid
  eventType     String
  entityType    String
  entityId      String
  maskedPayload Json
  createdAt     DateTime   @default(now())
  actor         AppProfile @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId, createdAt])
  @@index([correlationId])
}
